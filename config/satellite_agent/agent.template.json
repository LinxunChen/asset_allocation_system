    "cross_source_dedup_hours": 12,
    "poll_seconds": 60
  },
  "runtime_window": {
    "enabled": false,
    "timezone": "Asia/Shanghai",
    "weekdays": [
      "mon",
      "tue",
      "wed",
      "thu",
      "fri"
    ],
    "start_time": "18:00",
    "end_time": "04:00"
  },
  "notifications": {
    "feishu_webhook": "",
    "dry_run": false
  },
  "strategy": {
    "event_score_threshold": 60.0,
    "horizons": {
      "position": {
        "market_score_threshold": 55.0,
        "priority_threshold": 75.0
      },
      "swing": {
        "market_score_threshold": 55.0,
        "priority_threshold": 75.0
      }
    }
